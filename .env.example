# =============================================
# FICHIER MODÈLE — Ne jamais commit le vrai .env
# Copier ce fichier : cp .env.example .env
# Puis remplir avec vos vraies valeurs
# =============================================

# --- Base de données PostgreSQL ---
# Remplacer USER et PASSWORD par vos identifiants PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sensante?schema=public"

# --- Groq API (IA — Lab IA à venir) ---
# Obtenir la clé sur : https://console.groq.com
GROQ_API_KEY="votre_cle_api_groq_ici"

# --- NextAuth.js (Authentification — Lab Auth à venir) ---
# NEXTAUTH_SECRET : générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="un-secret-aleatoire-genere-avec-openssl"
NEXTAUTH_URL="http://localhost:3000"